# Generated output — do NOT commit
output/
outputs/
artifacts/

# Distribution and build — do NOT commit
dist/
build/
*.egg-info/
hal_yieldos.egg-info/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Test cache
.pytest_cache/
.pytest_tmp/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Linter cache
.ruff_cache/
.mypy_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# Release artifacts (generated by scripts/build_release.py)
*.zip
*.tar.gz
*.whl

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Environment files — never commit secrets
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Temporary
*.tmp
*.bak
